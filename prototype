<script>
const SM = {
  'welcome':'s-welcome','verify':'s-verify','guest':'s-guest',
  'history':'s-history','results':'s-results','dash':'s-dash',
  'calendar':'s-calendar','contract':'s-contract','guest-profile':'s-guest-profile'
};
const NM = {
  'welcome':'nb-welcome','verify':'nb-verify','guest':'nb-guest',
  'history':'nb-history','results':'nb-results','dash':'nb-dash',
  'calendar':'nb-calendar','contract':'nb-contract','guest-profile':'nb-guestprofile'
};

function goScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nf-btn').forEach(b => b.classList.remove('on'));
  if(SM[name]) document.getElementById(SM[name]).classList.add('active');
  if(NM[name]) document.getElementById(NM[name]).classList.add('on');
}

let role = 'guest';
function setRole(r) {
  role = r;
  document.getElementById('tog-guest').classList.toggle('on', r==='guest');
  document.getElementById('tog-host').classList.toggle('on', r==='host');
  document.getElementById('w-desc').textContent = r==='guest'
    ? "Trova l'appartamento perfetto. L'IA cerca tra proprietari verificati."
    : "Pubblica il tuo immobile in 2 minuti. L'IA scrive la descrizione dalle tue foto.";
  document.querySelector('#s-welcome .btn-orange').onclick = ()=> goScreen(r==='guest'?'verify':'dash');
}

function selectLevel(el) {
  document.querySelectorAll('.tl-card').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
}

function sendChat() {
  const t = document.getElementById('ci-text');
  const txt = t.value.trim(); if(!txt) return;
  const area = document.getElementById('chat-msgs');
  const typing = document.getElementById('typing-msg');
  const m = document.createElement('div');
  m.className='msg user';
  m.innerHTML=`<div class="bubble user">${txt}</div>`;
  area.insertBefore(m, typing);
  t.value=''; area.scrollTop=999999;
  setTimeout(()=>{ goScreen('results'); }, 1800);
}

// Init
document.querySelector('#s-welcome .btn-orange').onclick = ()=> goScreen('verify');
</script>
