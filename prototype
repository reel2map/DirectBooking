<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>locanda — App Prototype v2</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Instrument+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --teal: #0F4C5C;
  --bg: #FAF7F2;
  --orange: #FF7A00;
  --orange2: #FF9733;
  --text: #1F2933;
  --sky: #C7D9E2;
  --sky2: #e8f2f6;
  --mid: #6B7B84;
  --border: #E4DFD8;
  --white: #FFFFFF;
  --green: #1A7A5A;
  --green2: #e8f5ef;
  --red: #C0392B;
}

body {
  font-family: 'Instrument Sans', sans-serif;
  background: #0f0f1a;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 20px 120px;
}

.proto-header {
  text-align: center;
  margin-bottom: 28px;
}
.proto-header h1 {
  font-family: 'Syne', sans-serif;
  font-size: 26px; font-weight: 800; color: white; margin-bottom: 6px;
}
.proto-header p { font-size: 13px; color: rgba(255,255,255,0.35); }

/* PHONE */
.phone {
  width: 390px; height: 844px;
  background: var(--bg);
  border-radius: 52px;
  box-shadow: 0 0 0 12px #1e1e30, 0 0 0 14px #0a0a14, 0 40px 100px rgba(0,0,0,0.7);
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

/* STATUS */
.sb {
  height: 50px; background: inherit;
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 28px 0;
  font-size: 13px; font-weight: 600; color: var(--text);
  flex-shrink: 0; position: relative; z-index: 2;
}
.sb-icons { display: flex; gap: 5px; font-size: 11px; }

/* SCREENS */
.screen {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg);
  display: none; flex-direction: column; overflow: hidden;
}
.screen.active { display: flex; }

/* ── HELPERS ── */
.app-bar {
  background: white; flex-shrink: 0;
  border-bottom: 1px solid var(--border);
}
.ab-top {
  display: flex; align-items: center; justify-content: space-between;
  padding: 54px 18px 14px;
}
.ab-title { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 700; color: var(--text); }
.ab-sub { text-align: center; font-size: 11px; color: var(--mid); padding-bottom: 10px; }

.back { width: 36px; height: 36px; border-radius: 50%; background: var(--bg); border: none; cursor: pointer; font-size: 18px; color: var(--text); display: flex; align-items: center; justify-content: center; }

.scroll { flex: 1; overflow-y: auto; }
::-webkit-scrollbar { width: 0; }

.btn-orange {
  background: var(--orange); color: white; border: none;
  border-radius: 16px; padding: 17px; width: 100%;
  font-size: 16px; font-weight: 700; font-family: inherit; cursor: pointer;
  transition: all .2s; box-shadow: 0 4px 20px rgba(255,122,0,.35);
}
.btn-orange:hover { background: var(--orange2); transform: translateY(-1px); }

.btn-ghost {
  background: var(--bg); color: var(--mid); border: 1.5px solid var(--border);
  border-radius: 16px; padding: 17px; width: 100%;
  font-size: 15px; font-weight: 600; font-family: inherit; cursor: pointer;
}

.tab-bar {
  background: white; border-top: 1px solid var(--border);
  padding: 8px 0 24px; display: flex; flex-shrink: 0;
}
.tab-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; padding: 6px 0; }
.ti-icon { font-size: 22px; }
.ti-label { font-size: 10px; font-weight: 600; color: var(--mid); }
.tab-item.on .ti-label { color: var(--teal); }

.section-lbl {
  font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--mid); margin-bottom: 12px;
  display: flex; justify-content: space-between; align-items: center;
}
.section-lbl a { font-size: 12px; color: var(--teal); letter-spacing: 0; text-transform: none; font-weight: 600; }

.pill-tag {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 5px 12px; border-radius: 100px;
  font-size: 12px; font-weight: 700;
}

/* ══════════════════════════════════
   SCREEN 1 · WELCOME
══════════════════════════════════ */
#s-welcome {
  background: var(--teal);
  justify-content: center; align-items: center;
  text-align: center; padding: 0 32px;
}
.w-logo { font-family: 'Syne', sans-serif; font-size: 38px; font-weight: 800; color: white; margin-bottom: 6px; }
.w-logo span { color: var(--orange); }
.w-tag { font-size: 14px; color: rgba(255,255,255,.45); margin-bottom: 56px; font-weight: 300; }

.toggle-wrap { background: rgba(255,255,255,.12); border-radius: 100px; padding: 5px; display: flex; margin-bottom: 40px; width: 100%; max-width: 280px; }
.tog { flex: 1; padding: 13px 0; border: none; border-radius: 100px; font-size: 15px; font-weight: 700; font-family: inherit; cursor: pointer; transition: all .3s; background: transparent; color: rgba(255,255,255,.5); }
.tog.on { background: white; color: var(--teal); box-shadow: 0 4px 16px rgba(0,0,0,.2); }

.w-desc { font-size: 14px; color: rgba(255,255,255,.45); line-height: 1.6; margin-bottom: 36px; max-width: 260px; }
.w-note { font-size: 12px; color: rgba(255,255,255,.3); margin-top: 14px; }
.w-note strong { color: rgba(255,255,255,.6); }

/* ══════════════════════════════════
   SCREEN 2 · VERIFY
══════════════════════════════════ */
#s-verify {
  background: var(--bg);
}
.verify-body { padding: 24px 20px; display: flex; flex-direction: column; gap: 16px; }

.trust-levels { display: flex; flex-direction: column; gap: 10px; margin-bottom: 8px; }
.tl-card {
  background: white; border-radius: 18px; padding: 18px;
  border: 2px solid var(--border); display: flex; gap: 14px; align-items: center;
  transition: all .2s; cursor: pointer;
}
.tl-card.active { border-color: var(--teal); background: var(--sky2); }
.tl-badge { font-size: 24px; flex-shrink: 0; width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; background: var(--bg); }
.tl-info { flex: 1; }
.tl-name { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
.tl-desc { font-size: 12px; color: var(--mid); line-height: 1.4; }
.tl-check { color: var(--teal); font-size: 18px; opacity: 0; }
.tl-card.active .tl-check { opacity: 1; }

.doc-upload {
  background: white; border-radius: 18px; padding: 20px;
  border: 2px dashed var(--border);
  display: flex; flex-direction: column; align-items: center;
  gap: 8px; text-align: center; cursor: pointer;
  transition: border-color .2s;
}
.doc-upload:hover { border-color: var(--teal); }
.doc-upload-icon { font-size: 36px; }
.doc-upload-title { font-size: 14px; font-weight: 700; color: var(--text); }
.doc-upload-sub { font-size: 12px; color: var(--mid); }

.selfie-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.selfie-slot {
  background: white; border-radius: 16px; border: 2px dashed var(--border);
  aspect-ratio: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 6px;
  cursor: pointer; font-size: 12px; color: var(--mid); transition: all .2s;
}
.selfie-slot.done { background: var(--green2); border-color: var(--green); border-style: solid; }
.selfie-slot:hover { border-color: var(--teal); }
.ss-icon { font-size: 28px; }

/* ══════════════════════════════════
   SCREEN 3 · GUEST CHAT
══════════════════════════════════ */
#s-guest { background: var(--bg); }

.filter-bar {
  background: white; padding: 10px 14px;
  display: flex; gap: 7px; border-bottom: 1px solid var(--border);
  flex-shrink: 0; overflow-x: auto;
}
.fpill {
  display: flex; align-items: center; gap: 5px;
  background: var(--bg); border: 1.5px solid var(--border);
  border-radius: 100px; padding: 7px 12px;
  font-size: 12px; font-weight: 600; color: var(--text);
  white-space: nowrap; cursor: pointer; flex-shrink: 0; transition: all .2s;
}
.fpill.set { background: var(--sky2); border-color: var(--teal); color: var(--teal); }

.chat-area { flex: 1; overflow-y: auto; padding: 18px 14px; display: flex; flex-direction: column; gap: 14px; }
.msg { display: flex; gap: 8px; align-items: flex-end; }
.msg.ai { flex-direction: row; }
.msg.user { flex-direction: row-reverse; }
.ai-av { width: 30px; height: 30px; background: var(--teal); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
.bubble { max-width: 74%; padding: 11px 15px; border-radius: 20px; font-size: 14px; line-height: 1.5; }
.bubble.ai { background: white; color: var(--text); border-bottom-left-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
.bubble.user { background: var(--teal); color: white; border-bottom-right-radius: 4px; }
.typing { display: flex; gap: 4px; align-items: center; }
.dot { width: 7px; height: 7px; background: var(--mid); border-radius: 50%; animation: blink 1.2s infinite; }
.dot:nth-child(2){animation-delay:.2s} .dot:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,100%{opacity:.3;transform:translateY(0)}50%{opacity:1;transform:translateY(-3px)}}

.chat-input-row { background: white; border-top: 1px solid var(--border); padding: 10px 14px 28px; display: flex; gap: 8px; align-items: flex-end; flex-shrink: 0; }
.ci { flex: 1; background: var(--bg); border: 1.5px solid var(--border); border-radius: 20px; padding: 11px 14px; font-size: 14px; font-family: inherit; color: var(--text); outline: none; resize: none; line-height: 1.4; }
.send-btn { width: 42px; height: 42px; background: var(--orange); border: none; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; flex-shrink: 0; color: white; font-weight: 700; }

/* ══════════════════════════════════
   SCREEN 4 · CHAT HISTORY
══════════════════════════════════ */
#s-history { background: var(--bg); }
.history-list { padding: 16px; display: flex; flex-direction: column; gap: 10px; }
.hc-item {
  background: white; border-radius: 18px; padding: 16px;
  border: 1.5px solid var(--border); display: flex; gap: 12px;
  cursor: pointer; transition: all .2s;
}
.hc-item:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.07); }
.hc-item.unread { border-color: var(--orange); background: #FFF8F2; }
.hci-icon { width: 44px; height: 44px; border-radius: 14px; background: var(--sky2); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.hci-body { flex: 1; min-width: 0; }
.hci-top { display: flex; justify-content: space-between; margin-bottom: 3px; }
.hci-name { font-size: 14px; font-weight: 700; color: var(--text); }
.hci-time { font-size: 11px; color: var(--mid); }
.hci-preview { font-size: 13px; color: var(--mid); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hci-tags { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
.hci-tag { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 100px; background: var(--sky2); color: var(--teal); }

/* ══════════════════════════════════
   SCREEN 5 · RESULTS
══════════════════════════════════ */
#s-results { background: var(--bg); }
.rc { background: white; border-radius: 18px; overflow: hidden; border: 1.5px solid var(--border); cursor: pointer; transition: all .2s; margin-bottom: 10px; }
.rc:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.09); }
.rc-img { height: 100px; background: linear-gradient(135deg, #B8D4DC, #7FB5C5); display: flex; align-items: center; justify-content: center; font-size: 32px; position: relative; }
.rc-verified { position: absolute; top: 8px; left: 8px; background: var(--green); color: white; font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 100px; }
.rc-trust { position: absolute; top: 8px; right: 8px; background: rgba(0,0,0,.5); color: white; font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 100px; }
.rc-body { padding: 12px 14px; }
.rc-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
.rc-sub { font-size: 12px; color: var(--mid); margin-bottom: 8px; }
.rc-foot { display: flex; justify-content: space-between; align-items: center; }
.rc-price { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800; color: var(--teal); }
.rc-price small { font-family: inherit; font-size: 11px; font-weight: 400; color: var(--mid); }
.rc-cta { font-size: 12px; font-weight: 700; color: var(--orange); }

/* ══════════════════════════════════
   SCREEN 6 · HOST DASHBOARD
══════════════════════════════════ */
#s-dash { background: var(--bg); }

.dash-hdr {
  background: var(--teal); padding: 54px 20px 20px; flex-shrink: 0;
}
.dh-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.dh-greet { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 3px; }
.dh-name { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; color: white; letter-spacing: -.5px; }
.dh-av { width: 44px; height: 44px; background: var(--orange); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; color: white; font-family: 'Syne', sans-serif; }
.dh-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
.dhs { background: rgba(255,255,255,.1); border-radius: 14px; padding: 12px; text-align: center; }
.dhs-val { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; color: white; letter-spacing: -.5px; }
.dhs-val span { color: var(--orange); }
.dhs-lbl { font-size: 10px; color: rgba(255,255,255,.45); margin-top: 2px; }

.dash-body { flex: 1; overflow-y: auto; padding: 18px; }

.notif-card { background: white; border-radius: 18px; padding: 15px; margin-bottom: 10px; border: 1.5px solid var(--border); display: flex; gap: 11px; cursor: pointer; transition: all .2s; }
.notif-card:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.07); }
.notif-card.hot { border-color: var(--orange); background: #FFF8F2; }
.nc-icon { width: 42px; height: 42px; border-radius: 13px; background: var(--sky2); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.nc-body { flex: 1; }
.nc-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
.nc-sub { font-size: 12px; color: var(--mid); line-height: 1.4; }
.nc-actions { display: flex; gap: 8px; margin-top: 10px; }
.nc-confirm { flex: 1; padding: 9px; background: var(--orange); color: white; border: none; border-radius: 10px; font-size: 12px; font-weight: 700; font-family: inherit; cursor: pointer; }
.nc-decline { flex: 1; padding: 9px; background: var(--bg); border: 1.5px solid var(--border); border-radius: 10px; font-size: 12px; font-weight: 600; font-family: inherit; cursor: pointer; color: var(--mid); }

/* ══════════════════════════════════
   SCREEN 7 · CALENDAR
══════════════════════════════════ */
#s-calendar { background: var(--bg); }
.cal-wrap { padding: 16px; flex: 1; overflow-y: auto; }

.cal-month-nav {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px;
}
.cal-month-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; color: var(--text); }
.cal-nav-btn { width: 36px; height: 36px; border-radius: 50%; background: white; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; transition: all .2s; }
.cal-nav-btn:hover { background: var(--sky2); border-color: var(--teal); }

.cal-grid-head { display: grid; grid-template-columns: repeat(7,1fr); margin-bottom: 6px; }
.cal-dow { text-align: center; font-size: 11px; font-weight: 700; color: var(--mid); padding: 4px 0; }

.cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; margin-bottom: 20px; }
.cal-day {
  aspect-ratio: 1; border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 500; color: var(--text); cursor: pointer; position: relative;
  transition: all .15s;
}
.cal-day:hover { background: var(--sky2); }
.cal-day.empty { cursor: default; }
.cal-day.empty:hover { background: transparent; }
.cal-day.booked { background: var(--teal); color: white; font-weight: 700; }
.cal-day.pending { background: rgba(255,122,0,.15); color: var(--orange); font-weight: 700; }
.cal-day.blocked { background: var(--bg); color: var(--border); text-decoration: line-through; }
.cal-day.today { border: 2px solid var(--orange); font-weight: 700; }
.cal-day.range { background: var(--sky2); color: var(--teal); }

.cal-legend { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
.cl-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--mid); }
.cl-dot { width: 12px; height: 12px; border-radius: 4px; flex-shrink: 0; }

.booking-list { display: flex; flex-direction: column; gap: 8px; }
.bl-item { background: white; border-radius: 14px; padding: 14px; border: 1.5px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.bli-left { }
.bli-name { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
.bli-dates { font-size: 12px; color: var(--mid); }
.bli-price { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800; color: var(--teal); }

/* ══════════════════════════════════
   SCREEN 8 · CONTRACT
══════════════════════════════════ */
#s-contract { background: var(--bg); }
.contract-body { padding: 20px; flex: 1; overflow-y: auto; }

.contract-hero {
  background: var(--teal); border-radius: 20px; padding: 24px;
  text-align: center; margin-bottom: 20px;
}
.ch-icon { font-size: 44px; margin-bottom: 12px; display: block; }
.ch-title { font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 800; color: white; letter-spacing: -.5px; margin-bottom: 6px; }
.ch-sub { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.5; }

.contract-info { background: white; border-radius: 18px; padding: 20px; border: 1.5px solid var(--border); margin-bottom: 16px; }
.ci-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
.ci-row:last-child { border-bottom: none; }
.ci-label { color: var(--mid); font-weight: 500; }
.ci-value { color: var(--text); font-weight: 700; text-align: right; }

.contract-preview {
  background: white; border-radius: 18px; padding: 20px;
  border: 1.5px solid var(--border); margin-bottom: 16px;
  position: relative; overflow: hidden;
}
.cp-watermark {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%) rotate(-30deg);
  font-size: 48px; font-weight: 800; color: rgba(15,76,92,.06);
  font-family: 'Syne', sans-serif; white-space: nowrap; pointer-events: none;
}
.cp-title { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 800; color: var(--text); margin-bottom: 12px; letter-spacing: -.3px; }
.cp-text { font-size: 12px; color: var(--mid); line-height: 1.7; }
.cp-text strong { color: var(--text); font-weight: 600; }

.ai-gen-badge {
  display: flex; align-items: center; gap: 8px;
  background: rgba(26,122,90,.08); border: 1px solid rgba(26,122,90,.2);
  border-radius: 12px; padding: 10px 14px; margin-bottom: 16px;
  font-size: 12px; color: var(--green); font-weight: 600;
}

.sign-area { background: white; border-radius: 18px; padding: 20px; border: 2px dashed var(--border); text-align: center; margin-bottom: 16px; cursor: pointer; transition: border-color .2s; }
.sign-area:hover { border-color: var(--teal); }
.sign-icon { font-size: 28px; margin-bottom: 6px; }
.sign-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
.sign-sub { font-size: 12px; color: var(--mid); }

/* ══════════════════════════════════
   SCREEN 9 · VERIFY GUEST (from host POV)
══════════════════════════════════ */
#s-guest-profile { background: var(--bg); }
.gp-body { padding: 20px; flex: 1; overflow-y: auto; }

.gp-hero { text-align: center; margin-bottom: 24px; }
.gp-avatar { width: 80px; height: 80px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; font-size: 32px; margin: 0 auto 12px; position: relative; }
.gp-level { position: absolute; bottom: -4px; right: -4px; font-size: 16px; background: white; border-radius: 50%; width: 26px; height: 26px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,.15); }
.gp-name { font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; color: var(--text); letter-spacing: -.5px; margin-bottom: 4px; }
.gp-member { font-size: 12px; color: var(--mid); margin-bottom: 12px; }

.gp-badges { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-bottom: 20px; }
.gpb { display: flex; align-items: center; gap: 5px; padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 700; }
.gpb.blue { background: rgba(15,76,92,.1); color: var(--teal); }
.gpb.green { background: rgba(26,122,90,.1); color: var(--green); }
.gpb.gold { background: rgba(255,122,0,.1); color: var(--orange); }

